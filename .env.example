# Easy Waiver Suite — Environment Variables
# Copy this file to each app directory as .env and fill in your values.
# Each app has its own .env with the same variable names.

# ── Firebase Project ────────────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxx

# ── Firestore Database ───────────────────────────────────────────────────────
# Use '(default)' unless you created a named Firestore database
VITE_FIRESTORE_DB=(default)

# ── Cloud Functions ──────────────────────────────────────────────────────────
VITE_FUNCTIONS_BASE_URL=https://your-region-your-project.cloudfunctions.net
VITE_FUNCTIONS_REGION=us-central1

# ── App Check (public waiver-form and pilot-waiver apps only) ────────────────
VITE_RECAPTCHA_SITE_KEY=your-recaptcha-v3-site-key

# ── Local Development ────────────────────────────────────────────────────────
# Set to 'true' to route traffic through the Firebase Emulator Suite
VITE_USE_EMULATORS=false

# Set to 'true' to auto-generate an App Check debug token (printed to console)
# Or set to a specific registered debug token string
VITE_APPCHECK_DEBUG_TOKEN=
