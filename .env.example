# Easy Waiver Suite — Environment Variables
# ---------------------------------------------------------------------------
# SERVER (.env in repo root — used by docker-compose)
# ---------------------------------------------------------------------------

# Domain & TLS
DOMAIN=yourdomain.ca
ACME_EMAIL=admin@yourdomain.ca
# Generate with: htpasswd -n admin
TRAEFIK_DASHBOARD_AUTH=admin:$$apr1$$...

# PostgreSQL
POSTGRES_DB=easywaiver
POSTGRES_USER=easywaiver
POSTGRES_PASSWORD=change_me_strong_password

# MinIO (self-hosted S3 — PDF & logo storage)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_strong_password
MINIO_BUCKET=easy-waiver
MINIO_REGION=ca-east-1

# Redis
REDIS_PASSWORD=change_me_strong_password

# JWT — generate with: openssl rand -base64 64
JWT_ACCESS_SECRET=change_me_generate_with_openssl
JWT_REFRESH_SECRET=change_me_generate_with_openssl_different

# CORS — comma-separated allowed frontend origins
CORS_ORIGINS=https://form.yourdomain.ca,https://admin.yourdomain.ca,https://app.yourdomain.ca

# ---------------------------------------------------------------------------
# FRONTEND (VITE) — copy to each app's .env
# ---------------------------------------------------------------------------

# API base URL
VITE_API_URL=https://api.yourdomain.ca

# Org subdomain slug (identifies which tenant config to load)
VITE_TENANT_SLUG=your-org-slug

# ---------------------------------------------------------------------------
# LEGACY FIREBASE (kept for reference during migration — remove when done)
# ---------------------------------------------------------------------------
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
